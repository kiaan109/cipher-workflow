# Database (Neon Postgres recommended)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Polar billing
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=

# Credential encryption (for non-AI integrations, e.g. Discord/Slack webhooks)
ENCRYPTION_KEY=

# OpenRouter (powers all AI agent nodes with free models - no provider keys needed)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Band.ai (Band of Agents Hackathon - shared agent coordination rooms)
# Get your key at https://band.ai
BAND_API_KEY=
BAND_API_BASE_URL=https://api.band.ai/v1

# Email sending (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# VPS Worker (optional - bypasses Vercel's 10s timeout for long-running workflows)
# Set to your VPS URL if you have one, e.g. http://YOUR_VPS_IP:3001
WORKER_URL=
INTERNAL_API_SECRET=
